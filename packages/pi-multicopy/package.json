{
  "name": "pi-multicopy",
  "version": "0.1.0",
  "description": "Multi-select copy picker for Pi session tree nodes (with live preview + inline labels)",
  "keywords": ["pi-package", "pi", "pi-coding-agent"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w-winter/dot314.git",
    "directory": "packages/pi-multicopy"
  },
  "bugs": {
    "url": "https://github.com/w-winter/dot314/issues"
  },
  "homepage": "https://github.com/w-winter/dot314#readme",
  "pi": {
    "extensions": ["extensions/multicopy/index.ts"]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "scripts": {
    "prepack": "node ../../scripts/pi-package-prepack.mjs"
  },
  "files": ["extensions/**", "README.md", "LICENSE", "package.json"],
  "dot314Prepack": {
    "copy": [
      { "from": "../../extensions/multicopy/index.ts", "to": "extensions/multicopy/index.ts" },
      { "from": "../../extensions/multicopy/config.json", "to": "extensions/multicopy/config.json" },
      { "from": "../../LICENSE", "to": "LICENSE" }
    ]
  }
}
