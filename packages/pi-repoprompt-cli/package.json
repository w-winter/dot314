{
  "name": "pi-repoprompt-cli",
  "version": "0.4.0",
  "description": "Integrates RepoPrompt CE with Pi via RepoPrompt CE's `rpce-cli` executable",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "repoprompt",
    "repoprompt-ce"
],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w-winter/dot314.git",
    "directory": "packages/pi-repoprompt-cli"
  },
  "bugs": {
    "url": "https://github.com/w-winter/dot314/issues"
  },
  "homepage": "https://github.com/w-winter/dot314#readme",
  "pi": {
    "extensions": [
      "extensions/repoprompt-cli/index.ts"
    ]
  },
  "dependencies": {
    "diff": "^7.0.0",
    "just-bash": "^2.10.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "scripts": {
    "prepack": "node ../../scripts/pi-package-prepack.mjs"
  },
  "files": [
    "extensions/**",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "dot314Prepack": {
    "copy": [
      {
        "from": "../../extensions/repoprompt-cli/index.ts",
        "to": "extensions/repoprompt-cli/index.ts"
      },
      {
        "from": "../../extensions/repoprompt-cli/config.ts",
        "to": "extensions/repoprompt-cli/config.ts"
      },
      {
        "from": "../../extensions/repoprompt-cli/types.ts",
        "to": "extensions/repoprompt-cli/types.ts"
      },
      {
        "from": "../../extensions/repoprompt-cli/auto-select.ts",
        "to": "extensions/repoprompt-cli/auto-select.ts"
      },
      {
        "from": "../../extensions/repoprompt-cli/README.md",
        "to": "extensions/repoprompt-cli/README.md"
      },
      {
        "from": "../../extensions/repoprompt-cli/config.json.example",
        "to": "extensions/repoprompt-cli/config.json.example"
      },
      {
        "from": "../../extensions/repoprompt-cli/readcache",
        "to": "extensions/repoprompt-cli/readcache"
      },
      {
        "from": "../../LICENSE",
        "to": "LICENSE"
      }
    ]
  }
}